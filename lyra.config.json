{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "fast-filesystem-mcp"],
      "env": {
        "CREATE_BACKUP_FILES": "true",
        "DEBUG_MCP": "true",
        "MCP_SILENT_ERRORS": "true",
        "MCP_LOG_FILE": "/home/radek/Code/lyra-seed/logs/fast-fs-mcp.log"
      }
    },
    "shell": {
      "command": "uvx",
      "args": ["mcp-shell-server"],
      "env": {
        "ALLOW_COMMANDS": "ls,cat,pwd,grep,wc,touch,find,git,docker,python,pip,uv,uvx,npm,node,pnpm,npx,curl,ssh,gog"
      }
    },
    "firecrawl": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      }
    }
  },

  "dataDir": "./data",
  "systemPromptsDir": "./prompts",
  "skillsDir": "./skills",

  "defaultModel": "openai/gpt-5.4",

  "embeddingModel": "openai/text-embedding-3-large",

  "summaryModel": "openai/gpt-5.4-mini",
  "extractionModel": "openai/gpt-5.4-mini",
  "orchestrationModel": "openai/gpt-5.4-mini",
  
  "modelCosts": {
    "anthropic/claude-opus-4.6": [5.0, 25.0],
    "anthropic/claude-sonnet-4.6": [3.0, 15.0],
    "anthropic/claude-sonnet-4.5": [3.0, 15.0],
    "anthropic/claude-haiku-4.5": [1.0, 5.0],
    "arcee-ai/trinity-large-preview:free": [0.0, 0.0],
    "deepseek/deepseek-v3.2": [0.26, 0.38],
    "google/gemini-3.1-pro-preview": [2.0, 12.0],
    "google/gemini-3-flash-preview": [0.5, 3.0],
    "google/gemini-3.1-flash-lite-preview": [0.25, 1.5],
    "google/gemini-2.5-flash": [0.3, 2.5],
    "google/gemini-2.5-flash-lite": [0.1, 0.4],
    "google/gemini-2.0-flash-001": [0.1, 0.4],
    "minimax/minimax-m2.7": [0.3, 1.2],
    "minimax/minimax-m2.5": [0.118, 0.99],
    "moonshotai/kimi-k2.5": [0.3827, 1.72],
    "nvidia/nemotron-3-super-120b-a12b:free": [0.0, 0.0],
    "openai/gpt-5.4": [2.5, 15.0],
    "openai/gpt-5.3-codex": [1.75, 14.0],
    "openai/gpt-4o-mini": [0.15, 0.6],
    "openai/gpt-oss-120b": [0.039, 0.19],
    "qwen/qwen3-235b-a22b-2507": [0.071, 0.1],
    "qwen/qwen3.6-plus:free": [0.0, 0.0],
    "stepfun/step-3.5-flash:free": [0.0, 0.0],
    "x-ai/grok-4.1-fast": [0.2, 0.5],
    "x-ai/grok-4-fast": [0.2, 0.5],
    "xiaomi/mimo-v2-pro": [1.0, 3.0],
    "xiaomi/mimo-v2-omni": [0.4, 2.0],
    "xiaomi/mimo-v2-flash": [0.09, 0.29],
    "z-ai/glm-5-turbo": [1.2, 4.0],
    "z-ai/glm-5": [0.72, 2.3]
  },
  "defaultModelCost": [1.0, 5.0],

  "retry": {
    "max_retries": 3,
    "base_delay": 1.0,
    "max_delay": 30.0,
    "timeout": 60.0
  },

  "hitl": {
    "timeout_seconds": 300
  },

  "memoryGC": {
    "prune_threshold": 0.1,
    "max_entries": 500,
    "dedup_threshold": 0.9,
    "half_life_days": 7.0,
    "decay_weights": [0.6, 0.2, 0.2]
  },

  "context": {
    "max_tokens": 100000,
    "memory_top_k": 5
  },

  "maxSubtasks": 10,
  "orchestrationTemperature": 0.3,
  "mcpRequestTimeout": 30.0,
  "maxSpawnDepth": 3
}
