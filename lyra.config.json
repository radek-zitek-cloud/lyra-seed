    "shell": {
      "command": "npx",
      "args": ["-y", "@simonb97/server-win-cli"],
      "env": {
      }
    }
  },
  "systemPromptsDir": "./prompts",
  "defaultModel": "openai/gpt-5.4",
  "embeddingModel": "openai/text-embedding-3-large"
}
