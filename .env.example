# Lyra Agent Platform — Environment Configuration
# Secrets and server bind config only. Everything else in lyra.config.json.

# OpenRouter API key (required for LLM calls)
LYRA_OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Backend server host and port
LYRA_HOST=0.0.0.0
LYRA_PORT=8000

# CORS allowed origins (comma-separated, for frontend access)
LYRA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
