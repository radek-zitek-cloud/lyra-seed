# Lyra Agent Platform — Environment Configuration
# Copy to .env and fill in your values.

# OpenRouter API key (required for LLM calls)
LYRA_OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Default LLM model via OpenRouter
LYRA_DEFAULT_MODEL=minimax/minimax-m2.7

# SQLite database path
LYRA_DB_PATH=lyra.db

# Backend server host and port
LYRA_HOST=0.0.0.0
LYRA_PORT=8000
