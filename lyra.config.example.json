{
  "dataDir": "./data",
  "defaultModel": "openai/gpt-4.1-mini",
  "embeddingModel": "openai/text-embedding-3-large",
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "fast-filesystem-mcp"],
      "env": {
        "CREATE_BACKUP_FILES": "true",
        "DEBUG_MCP": "true",
        "MCP_SILENT_ERRORS": "true",
        "MCP_LOG_FILE": "/home/radek/Code/lyra-seed/logs/fast-fs-mcp.log"
      }
    },
    "shell": {
      "command": "uvx",
      "args": ["mcp-shell-server"],
      "env": {
        "ALLOW_COMMANDS": "powershell,pwsh,Get-ChildItem,Get-Content,Get-Location,Select-String,Measure-Object,New-Item,Set-Content,Add-Content,Remove-Item,Copy-Item,Move-Item,Test-Path,Resolve-Path,Get-ItemProperty,Set-Location,Write-Output,Out-File,ConvertTo-Json,ConvertFrom-Json,Get-Process,Stop-Process,Get-Service,Invoke-WebRequest,Invoke-RestMethod,git,docker,python,pip,npm,node,curl,dotnet,where.exe,Get-Command,Get-Help,Get-Date,Get-Host,Format-Table,Format-List,Sort-Object,Where-Object,ForEach-Object,Select-Object,Group-Object,Compare-Object,Out-String"
      }
    }
  },
  "systemPromptsDir": "./prompts",
  "modelCosts": {
    "openai/gpt-4.1": [2.0, 8.0],
    "openai/gpt-4.1-mini": [0.4, 1.6],
    "openai/gpt-4.1-nano": [0.1, 0.4],
    "openai/text-embedding-3-large": [0.13, 0.0],
    "anthropic/claude-sonnet-4": [3.0, 15.0],
    "anthropic/claude-haiku-4": [0.8, 4.0]
  },
  "defaultModelCost": [1.0, 4.0],

  "retry": {
    "max_retries": 3,
    "base_delay": 1.0,
    "max_delay": 30.0,
    "timeout": 60.0
  },

  "hitl": {
    "timeout_seconds": 300
  },

  "memoryGC": {
    "prune_threshold": 0.1,
    "max_entries": 500,
    "dedup_threshold": 0.9,
    "half_life_days": 7.0,
    "decay_weights": [0.6, 0.2, 0.2]
  },

  "context": {
    "max_tokens": 100000,
    "memory_top_k": 5
  },

  "summaryModel": "openai/gpt-4.1-nano",
  "extractionModel": "openai/gpt-4.1-nano",
  "orchestrationModel": "openai/gpt-4.1-mini",
  "orchestrationTemperature": 0.3,
  "maxSubtasks": 10,
  "mcpRequestTimeout": 30.0,
  "maxSpawnDepth": 3
}
