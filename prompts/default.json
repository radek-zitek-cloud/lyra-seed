{
  "model": "openai/gpt-5.4",
  "temperature": 0.7,
  "max_iterations": 15,
  "hitl_policy": "never",
  "auto_extract": true,

  "summary_model": "openai/gpt-5.4-mini",
  "extraction_model": "openai/gpt-5.4-mini",
  "orchestration_model": "openai/gpt-5.4-mini",
 
  "max_subtasks": 10,

  "retry": {
    "max_retries": 3,
    "base_delay": 1.0,
    "max_delay": 30.0,
    "timeout": 60.0
  },

  "hitl": {
    "timeout_seconds": 300
  },

  "memoryGC": {
    "prune_threshold": 0.1,
    "max_entries": 500,
    "dedup_threshold": 0.9
  },

  "context": {
    "max_tokens": 100000,
    "memory_top_k": 5
  },

  "memory_sharing": {
    "fact": "public",
    "procedure": "public",
    "tool_knowledge": "public",
    "domain_knowledge": "public",
    "preference": "private",
    "decision": "private",
    "episodic": "private",
    "outcome": "private"
  }
}
