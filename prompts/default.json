{
  "model": "google/gemini-3.1-pro-preview",
  "summary_model": "google/gemini-3.1-flash-lite-preview",
  "extraction_model": "google/gemini-3.1-flash-lite-preview",
  "orchestration_model": "google/gemini-3.1-flash-lite-preview",

  "hitl_policy": "never",
  "auto_extract": true,
  "temperature": 0.7,
  "max_iterations": 20,
  "max_subtasks": 20,

  "retry": {
    "max_retries": 3,
    "base_delay": 1.0,
    "max_delay": 30.0,
    "timeout": 60.0
  },

  "hitl": {
    "timeout_seconds": 300
  },

  "memoryGC": {
    "prune_threshold": 0.1,
    "max_entries": 500,
    "dedup_threshold": 0.9,
    "half_life_days": 7.0,
    "decay_weights": [0.6, 0.2, 0.2]
  },

  "context": {
    "max_tokens": 100000,
    "memory_top_k": 5
  },

  "memory_sharing": {
    "fact": "public",
    "procedure": "public",
    "tool_knowledge": "public",
    "domain_knowledge": "public",
    "preference": "private",
    "decision": "private",
    "episodic": "private",
    "outcome": "private"
  }
}
